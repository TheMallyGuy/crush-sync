{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "crush-sync",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-14",
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "283b1cf9e8fe4a66b8311eb9d07daa8e" // replace this with your kv if youre self hosting
    }
  ],
  "vars": {
    "DISCORD_REDIRECT_URI": "https://cloud-config.mally.qzz.io/auth/callback"
  }
